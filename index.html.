<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Lex Bufete - Cotizador de Hipotecas</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        .bg-legal { background-color: #1a2a3a; }
        .text-legal { color: #1a2a3a; }
        input:focus, select:focus { border-color: #1a2a3a !important; outline: none; }
        
        /* Estilos del documento a exportar */
        #cotizacion-export {
            background-color: white;
            font-family: 'Times New Roman', Times, serif;
            color: #000;
        }
    </style>
</head>
<body class="bg-gray-100 min-h-screen pb-10">

    <header class="bg-legal text-white p-6 shadow-lg mb-6 flex justify-between items-center">
        <div>
            <h1 class="text-xl font-bold tracking-widest uppercase">Lex Bufete</h1>
            <p class="text-xs opacity-80 mt-1">Generador de Cotizaciones</p>
        </div>
    </header>

    <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <div class="lg:col-span-4 space-y-6">
            <div class="bg-white rounded-xl shadow-md p-6 border-t-4 border-blue-900">
                <h3 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2">Datos del Trámite</h3>
                
                <div class="space-y-4">
                    <div>
                        <label class="block text-[11px] font-bold text-gray-500 uppercase">Dirigido a:</label>
                        <input type="text" id="dirigido" value="ACACYPAC" class="w-full p-2 border border-gray-300 rounded focus:ring-2 bg-gray-50">
                    </div>
                    <div>
                        <label class="block text-[11px] font-bold text-gray-500 uppercase">Cliente (Hipotecante):</label>
                        <input type="text" id="cliente" placeholder="Nombre completo" class="w-full p-2 border border-gray-300 rounded focus:ring-2 bg-gray-50">
                    </div>
                    <div>
                        <label class="block text-[11px] font-bold text-gray-500 uppercase">Tipo de Trámite:</label>
                        <select id="tramite" class="w-full p-2 border border-gray-300 rounded focus:ring-2 bg-gray-50 font-semibold">
                            <option value="Hipoteca Simple">Hipoteca Simple</option>
                            <option value="Hipoteca Abierta">Hipoteca Abierta</option>
                            <option value="Cancelación de Hipoteca">Cancelación de Hipoteca</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-[11px] font-bold text-gray-500 uppercase">Monto ($):</label>
                        <input type="number" id="monto" inputmode="decimal" placeholder="Ej. 10000" class="w-full p-3 border border-blue-200 rounded focus:ring-2 text-xl font-bold bg-blue-50">
                    </div>
                    <div>
                        <label class="block text-[11px] font-bold text-gray-500 uppercase flex justify-between">
                            <span>Honorarios Lex Bufete ($):</span>
                            <span class="text-blue-600 font-normal normal-case text-[10px]">*Editable</span>
                        </label>
                        <input type="number" id="honorario" inputmode="decimal" placeholder="0.00" class="w-full p-3 border border-gray-300 rounded focus:ring-2 text-xl font-bold">
                    </div>
                </div>

                <button onclick="compartir()" class="w-full mt-6 flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 rounded-lg shadow-md transition-all uppercase text-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                    </svg>
                    Compartir / Guardar
                </button>
            </div>
        </div>

        <div class="lg:col-span-8 overflow-x-auto">
            <div id="cotizacion-export" class="p-10 shadow-xl border border-gray-200 mx-auto" style="min-width: 600px; max-width: 800px;">
                
                <div class="flex justify-between items-end mb-8 border-b-2 border-blue-900 pb-4">
                    <div>
                        <h2 class="text-2xl font-black text-blue-900 tracking-widest uppercase">Corporación Lex Bufete</h2>
                        <p class="text-xs text-gray-600 uppercase tracking-widest">Servicios Jurídicos y Notariales</p>
                    </div>
                    <div class="text-right text-sm text-gray-700 font-bold">
                        <span id="fecha-actual"></span>
                    </div>
                </div>

                <div class="mb-8">
                    <p class="text-sm">Señores</p>
                    <p class="text-xl font-bold uppercase" id="out-dirigido">ACACYPAC</p>
                    <p class="text-sm">Presente.</p>
                </div>

                <div class="mb-10 text-justify text-base leading-relaxed text-gray-800">
                    <p>De nuestra mayor consideración:</p>
                    <p class="mt-4">
                        Por este medio presentamos la cotización de los gastos de aranceles registrales y honorarios notariales correspondientes al trámite de <strong id="out-tramite" class="uppercase">HIPOTECA SIMPLE</strong> por un monto de <strong id="out-monto">$0.00</strong>, a favor de su cliente <strong id="out-cliente" class="uppercase">_________________</strong>.
                    </p>
                </div>

                <div class="mb-10">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-100 border-b-2 border-gray-400">
                                <th class="p-3 text-sm font-bold uppercase">Descripción</th>
                                <th class="p-3 text-sm font-bold uppercase text-right w-40">Monto</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-b border-gray-200">
                                <td class="p-3">Aranceles CNR (Registro de la Propiedad Raíz e Hipotecas)</td>
                                <td class="p-3 text-right font-mono" id="out-arancel">$0.00</td>
                            </tr>
                            <tr class="border-b border-gray-200">
                                <td class="p-3">Honorarios Profesionales (Lex Bufete)</td>
                                <td class="p-3 text-right font-mono" id="out-honorario">$0.00</td>
                            </tr>
                            <tr class="bg-blue-50 border-t-2 border-blue-900">
                                <td class="p-3 text-right font-black uppercase text-blue-900">Total de Inversión</td>
                                <td class="p-3 text-right font-black font-mono text-xl text-blue-900" id="out-total">$0.00</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="mb-16">
                    <p class="text-justify text-sm italic text-gray-700">
                        Agradeciendo de antemano la confianza depositada en Corporación Lex Bufete, quedo a su entera disposición para cualquier consulta adicional.
                    </p>
                </div>

                <div class="text-center mt-12 mb-8">
                    <p class="text-sm mb-4">Atentamente,</p>
                    <img src="firma.png" alt="Firma Representante Legal" class="h-24 mx-auto object-contain" onerror="this.style.display='none'">
                    <div class="border-t border-black inline-block px-10 pt-2 mt-1">
                        <p class="font-bold text-sm uppercase">Representante Legal</p>
                        <p class="text-sm">Corporación Lex Bufete</p>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        // Referencias a los elementos del formulario
        const dirigidoIn = document.getElementById('dirigido');
        const clienteIn = document.getElementById('cliente');
        const tramiteIn = document.getElementById('tramite');
        const montoIn = document.getElementById('monto');
        const honorarioIn = document.getElementById('honorario');

        // Referencias a los elementos de la Vista Previa
        const outDirigido = document.getElementById('out-dirigido');
        const outCliente = document.getElementById('out-cliente');
        const outTramite = document.getElementById('out-tramite');
        const outMonto = document.getElementById('out-monto');
        const outArancel = document.getElementById('out-arancel');
        const outHonorario = document.getElementById('out-honorario');
        const outTotal = document.getElementById('out-total');

        // Establecer Fecha Actual
        const opcionesFecha = { year: 'numeric', month: 'long', day: 'numeric' };
        document.getElementById('fecha-actual').innerText = new Date().toLocaleDateString('es-ES', opcionesFecha);

        // Lógica de Aranceles CNR (Art. 48)
        function calcularArancel(monto, tipo) {
            if (monto <= 0) return 0;
            if (tipo === "Hipoteca Simple") {
                return Math.ceil(monto / 100) * 0.38;
            } else if (tipo === "Hipoteca Abierta") {
                return Math.ceil(monto / 100) * 0.63;
            } else if (tipo === "Cancelación de Hipoteca") {
                if (monto <= 9000) {
                    return 8.91;
                } else {
                    return 8.91 + (Math.ceil((monto - 9000) / 100) * 0.13);
                }
            }
            return 0;
        }

        // Lógica de Honorarios Lex Bufete (Precios ACACYPAC)
        function calcularHonorariosSugeridos(monto) {
            if (monto <= 0) return 0;
            if (monto < 4000) return 40;
            if (monto < 10000) return 60;
            if (monto < 20000) return 75;
            if (monto < 30000) return 90;
            if (monto < 40000) return 100;
            if (monto < 50000) return 110;
            if (monto < 75000) return 150;
            if (monto < 100000) return 175;
            if (monto < 150000) return 200;
            return 225;
        }

        // Formateador de moneda
        function fMoneda(valor) {
            return "$" + valor.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
        }

        // Función para inyectar datos en la Carta
        function actualizarVista() {
            const monto = parseFloat(montoIn.value) || 0;
            const tipo = tramiteIn.value;
            const honorario = parseFloat(honorarioIn.value) || 0;
            const arancel = calcularArancel(monto, tipo);
            const total = arancel + honorario;

            outDirigido.innerText = dirigidoIn.value || "ACACYPAC";
            outCliente.innerText = clienteIn.value || "_________________";
            outTramite.innerText = tipo;
            outMonto.innerText = fMoneda(monto);
            outArancel.innerText = fMoneda(arancel);
            outHonorario.innerText = fMoneda(honorario);
            outTotal.innerText = fMoneda(total);
        }

        // Evento principal: Cuando cambia el monto, se autocalculan los honorarios
        montoIn.addEventListener('input', () => {
            const monto = parseFloat(montoIn.value) || 0;
            honorarioIn.value = calcularHonorariosSugeridos(monto);
            actualizarVista();
        });

        // Eventos secundarios: Actualizar la vista al escribir en los demás campos
        dirigidoIn.addEventListener('input', actualizarVista);
        clienteIn.addEventListener('input', actualizarVista);
        tramiteIn.addEventListener('change', actualizarVista);
        honorarioIn.addEventListener('input', actualizarVista); // Por si se modifica manualmente

        // Inicializar la vista al cargar
        actualizarVista();

        // Función para Generar Imagen y Compartir
        async function compartir() {
            const nodoCarta = document.getElementById('cotizacion-export');
            
            // Toma captura del HTML y lo convierte en Imagen (Canvas)
            html2canvas(nodoCarta, { scale: 2 }).then(canvas => {
                canvas.toBlob(async function(blob) {
                    const nombreArchivo = "Cotizacion_Lex_Bufete.png";
                    const archivo = new File([blob], nombreArchivo, { type: "image/png" });
                    
                    // Si el dispositivo es un móvil y soporta compartir archivos nativamente (WhatsApp, etc.)
                    if (navigator.canShare && navigator.canShare({ files: [archivo] })) {
                        try {
                            await navigator.share({
                                title: 'Cotización Lex Bufete',
                                files: [archivo]
                            });
                        } catch (error) {
                            console.log("El usuario canceló el menú de compartir.");
                        }
                    } else {
                        // En computadora, se descarga la imagen automáticamente
                        const enlace = document.createElement('a');
                        enlace.download = nombreArchivo;
                        enlace.href = canvas.toDataURL('image/png');
                        enlace.click();
                    }
                });
            });
        }
    </script>
</body>
</html>
